#!/data/data/com.termux/files/usr/bin/bash

# ============================================
# TermuxVoid Package Manager
# Version: 2.0.6
# Maintained by: Anon4You
# ============================================

# Color Variables
RED='\e[1;31m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
CYAN='\e[1;36m'
NC='\e[0m'

# Current Version
current_version="2.0.7"

# Trap Ctrl+C to kill any background processes
cleanup() {
    kill $(jobs -p) 2>/dev/null
    echo -e "\n${RED}Interrupted.${NC}"
    exit 1
}
trap cleanup INT TERM

# ------------------------------------------------------------
# Display the retro banner
# ------------------------------------------------------------
display_banner() {
    clear
    echo -e "
                _____
             ,-\"     \"-.
            / o       o \\
           /   \\     /   \\
          /     )-\"-(     \\
         /     ( 6 6 )     \\
        /       \\ 6 /       \\
       /         )=(         \\
      /   o   .--\"-\"--.   o   \\
     /    I  /  -   -  \\  I    \\
 .--(    (_}y/\\       /\\y{_)    )--.
(    \".___l\\/__\\_____/__\\/l___,\"    )
 \\                                 /
  \"-._      o O o O o O o      _,-\"
      \`--Y--.___________.--Y--'
         |==.${CYAN}Alienkrishn${NC}.==|
         \`==.___________.=='
"
}

# ------------------------------------------------------------
# Show the main menu
# ------------------------------------------------------------
show_menu() {
    display_banner
    echo -e "\n++--==[ ${YELLOW}TermuxVoid Package Manager${NC} ]==--++"
    echo -e "++--==[ Version: ${GREEN}${current_version}${NC} | Maintained By: ${CYAN}Anon4You${NC} ]==--++\n"

    echo -e "${BLUE}MAIN MENU:${NC}"
    echo -e "  ${GREEN}[1]${NC} Follow Developer"
    echo -e "  ${GREEN}[2]${NC} List Available Packages"
    echo -e "  ${GREEN}[3]${NC} Package Management Help"
    echo -e "  ${GREEN}[4]${NC} Update Repository Keys"
    echo -e "  ${GREEN}[5]${NC} Install TermuxVoid Theme"
    echo -e "  ${GREEN}[6]${NC} Change Termux Font"
    echo -e "  ${GREEN}[7]${NC} System Information"
    echo -e "  ${GREEN}[8]${NC} Quick System Update"
    echo -e "  ${GREEN}[9]${NC} Cleanup System"
    echo -e "  ${RED}[0]${NC} Exit\n"
}

# ------------------------------------------------------------
# Error handler with suggested solution
# ------------------------------------------------------------
handle_error() {
    echo -e "\n${RED}[!] ERROR:${NC} $1"
    echo -e "${YELLOW}[?] SOLUTION:${NC} $2\n"
    sleep 2
}

# ------------------------------------------------------------
# Network check using curl (more reliable than ping)
# ------------------------------------------------------------
check_network() {
    if ! curl -s --head --connect-timeout 5 http://google.com | head -n 1 | grep "HTTP/[0-9.]* [23]" >/dev/null; then
        handle_error "No internet connection detected." "Please check your network and try again."
        return 1
    fi
    return 0
}

# ------------------------------------------------------------
# Spinner animation for background processes
# Usage: (long_running_command) & spinner $!
# ------------------------------------------------------------
spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='|/-\'
    while kill -0 "$pid" 2>/dev/null; do
        printf " [%c]  " "$spinstr"
        spinstr=${spinstr#?}${spinstr%"${spinstr#?}"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# ------------------------------------------------------------
# Change Termux font using void-fonts
# ------------------------------------------------------------
change_termux_font() {
    echo -e "\n${BLUE}=== Change Termux Font ===${NC}"

    if ! command -v vfonts &>/dev/null; then
        echo -e "${YELLOW}Font tool not found. Installing void-fonts...${NC}"
        if ! apt install -y void-fonts >/dev/null 2>&1; then
            handle_error "Failed to install void-fonts." "Check your internet connection and try again."
            return 1
        fi
    fi

    echo -e "\n${CYAN}Select your preferred font:${NC}"
    echo -e "${YELLOW}Use arrow keys to navigate, Enter to select, ESC to cancel${NC}\n"
    vfonts

    echo -e "\n${GREEN}Font changed successfully!${NC}"
    echo -e "${YELLOW}Note: Restart Termux to see changes.${NC}"
}

# ------------------------------------------------------------
# List packages from termuxvoid repo with descriptions
# ------------------------------------------------------------
list_and_install_packages() {
    check_network || return 1

    echo -e "\n${BLUE}=== Available Packages ===${NC}"
    echo -e "${YELLOW}Fetching package list...${NC}\n"

    # Get list of package names from termuxvoid repo (ignore apt warning header)
    mapfile -t packages < <(apt list -a 2>/dev/null | grep -v "^Listing..." | grep "/termuxvoid" | cut -d/ -f1)

    if [[ ${#packages[@]} -eq 0 ]]; then
        handle_error "No packages found." "Try running 'apt update' first."
        return 1
    fi

    echo -e "${CYAN}Available TermuxVoid Packages:${NC}\n"

    # Collect descriptions
    declare -a descriptions
    for pkg in "${packages[@]}"; do
        desc=$(apt show "$pkg" 2>/dev/null | sed -n '/^Description:/ { s/^Description://; s/^ //; p; q }')
        if [[ -z "$desc" ]]; then
            desc="No description available"
        fi
        descriptions+=("$desc")
    done

    # Display numbered list with descriptions
    for i in "${!packages[@]}"; do
        printf "  ${GREEN}%3d${NC} %s - %s\n" $((i+1)) "${packages[$i]}" "${descriptions[$i]}"
    done

    echo -e "\n  ${RED} 0${NC} Back to Main Menu\n"

    while true; do
        read -p "$(echo -e ${CYAN}"Enter package number to install > "${NC})" pkg_num

        if [[ "$pkg_num" =~ ^[0-9]+$ ]]; then
            if [[ $pkg_num -eq 0 ]]; then
                return 0
            elif (( pkg_num > 0 && pkg_num <= ${#packages[@]} )); then
                selected_pkg="${packages[$((pkg_num-1))]}"
                echo -e "\n${YELLOW}Installing ${selected_pkg}...${NC}\n"

                # Run installation in background with spinner (hide output)
                apt install -y "$selected_pkg" >/dev/null 2>&1 &
                pid=$!
                spinner $pid
                wait $pid
                if [ $? -eq 0 ]; then
                    echo -e "\n${GREEN}[✓] ${selected_pkg} installed successfully!${NC}\n"
                else
                    handle_error "Installation failed." "Check dependencies or storage space."
                fi
                return 0
            else
                handle_error "Invalid number." "Please enter between 0 and ${#packages[@]}."
            fi
        else
            handle_error "Invalid input." "Numbers only please."
        fi
    done
}

# ------------------------------------------------------------
# Main program loop
# ------------------------------------------------------------
while true; do
    show_menu
    # Stylish prompt
    read -p "$(echo -e "${CYAN}❯ ${NC}")" selection

    case $selection in
        1) # Follow Developer
            echo -e "\n${BLUE}=== Developer Information ===${NC}"
            echo -e "${CYAN}GitHub:${NC} https://github.com/Anon4You"
            echo -e "${CYAN}Opening in browser...${NC}"
            xdg-open "https://github.com/Anon4You" 2>/dev/null || echo -e "${YELLOW}Couldn't open browser. Please visit the URL manually.${NC}"
            ;;

        2) # List Packages
            list_and_install_packages
            ;;

        3) # Help
            echo -e "\n${BLUE}=== Package Management Help ===${NC}"
            echo -e "${CYAN}Basic Commands:${NC}"
            echo -e "  ${GREEN}Search:${NC}    apt search <package>"
            echo -e "  ${GREEN}Install:${NC}   apt install <package>"
            echo -e "  ${GREEN}Upgrade:${NC}   apt upgrade"
            echo -e "  ${GREEN}Remove:${NC}    apt remove <package>"
            echo -e "  ${GREEN}Info:${NC}      apt show <package>"
            ;;

        4) # Update Repository Keys (fixed)
            echo -e "\n${BLUE}=== Updating Repository Keys ===${NC}"
            check_network || continue
            echo -e "${YELLOW}Downloading new keys...${NC}"
            mkdir -p "$PREFIX/etc/apt/trusted.gpg.d"
            if curl -sL https://termuxvoid.github.io/repo/termuxvoid.gpg -o "$PREFIX/etc/apt/trusted.gpg.d/termuxvoid.gpg"; then
                echo -e "${GREEN}Key downloaded, updating package lists...${NC}"
                (apt update -y) >/dev/null 2>&1 &
                spinner $!
                wait $!
                echo -e "\n${GREEN}[✓] Repository keys updated successfully!${NC}"
            else
                handle_error "Key download failed." "Check your internet connection."
            fi
            ;;

        5) # Install Theme
            echo -e "\n${BLUE}=== Theme Installation ===${NC}"
            check_network || continue
            echo -e "${YELLOW}Downloading theme...${NC}"
            if curl -LO https://github.com/termuxvoid/TermuxVoid-Theme/raw/main/termuxvoid-theme.sh && \
               bash termuxvoid-theme.sh; then
                echo -e "\n${GREEN}[✓] Theme installed successfully!${NC}"
                echo -e "${YELLOW}Restart Termux to see changes.${NC}"
                rm -f termuxvoid-theme.sh
            else
                handle_error "Theme installation failed." "Check storage permissions."
            fi
            ;;

        6) # Change Font
            change_termux_font
            ;;

        7) # System Info
            echo -e "\n${BLUE}=== System Information ===${NC}"
            echo -e "OS: $(uname -o)"
            echo -e "Architecture: $(uname -m)"
            echo -e "Storage: $(df -h $PREFIX | awk 'NR==2{print $4}') free"
            echo -e "Termux Version: ${TERMUX_VERSION:-Unknown}"
            ;;

        8) # Quick System Update
            echo -e "\n${BLUE}=== Quick System Update ===${NC}"
            check_network || continue
            echo -e "${YELLOW}Updating package lists and upgrading...${NC}"
            (apt update && apt upgrade -y) >/dev/null 2>&1 &
            spinner $!
            wait $!
            echo -e "\n${GREEN}System updated successfully!${NC}"
            ;;

        9) # Cleanup
            echo -e "\n${BLUE}=== System Cleanup ===${NC}"
            echo -e "${YELLOW}Cleaning package cache...${NC}"
            (apt clean) >/dev/null 2>&1 &
            spinner $!
            wait $!
            echo -e "${YELLOW}Removing unused packages...${NC}"
            (apt autoremove -y) >/dev/null 2>&1 &
            spinner $!
            wait $!
            echo -e "\n${GREEN}Cleanup completed!${NC}"
            ;;

        0) # Exit
            echo -e "\n${GREEN}Goodbye!${NC}\n"
            exit 0
            ;;

        *) # Invalid
            handle_error "Invalid selection." "Please choose 0-9"
            ;;
    esac

    echo -e "${YELLOW}Press Enter to continue...${NC}" && read dummy
done
