#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling amass...${NC}"

if [ -f "$PREFIX/bin/amass" ]; then
    rm -f $PREFIX/bin/amass
    echo -e "${GREEN}Removed amass binary${NC}"
fi

echo -e "${GREEN}amass completely removed${NC}"
exit 0
