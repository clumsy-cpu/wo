#!/data/data/com.termux/files/usr/bin/bash

echo "Starting Android SDK installation..."

ANDROID_DIR="$PREFIX/opt/android-sdk"

# Create directory
if [ -d "$ANDROID_DIR" ]; then
    rm -rf "$ANDROID_DIR"
fi

mkdir -p "$PREFIX/opt"

echo "Downloading Android SDK..."
axel -n 4 -o $TMPDIR/android-sdk.tar.xz https://github.com/termuxvoid/android-sdk-termux/releases/download/36.0.0/android-sdk.7z

echo "Extracting SDK..."
7z x $TMPDIR/android-sdk.tar.xz -o"$PREFIX/opt" -y > /dev/null

rm $TMPDIR/android-sdk.tar.xz

echo "Verifying installation..."

# Get versions dynamically
BUILD_TOOLS_VERSION=$(ls "$ANDROID_DIR/build-tools/" | head -1)
NDK_VERSION=$(ls "$ANDROID_DIR/ndk/" | head -1)
CMAKE_VERSION=$(ls "$ANDROID_DIR/cmake/" | head -1)

echo ""
echo "Installation complete!"
echo "Android SDK is installed at: $ANDROID_DIR"
echo ""
echo "=== EDIT APP PROPERTIES ==="
echo ""
echo "1. Edit android/gradle.properties:"
echo "   Add: android.aapt2FromMavenOverride=$ANDROID_DIR/build-tools/$BUILD_TOOLS_VERSION/aapt2"
echo ""
echo "2. Edit android/local.properties:"
echo "   Add:"
echo "   sdk.dir=$ANDROID_DIR"
echo "   ndk.dir=$ANDROID_DIR/ndk/$NDK_VERSION"
echo "   cmake.dir=$ANDROID_DIR/cmake/$CMAKE_VERSION"
echo ""
echo "Note: No PATH or environment variables needed."
