#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing AntiSplit 1.0...${NC}"

# Clone AntiSplit repository
echo -e "${YELLOW}Cloning AntiSplit repository...${NC}"
git clone https://github.com/termuxvoid/AntiSplit.git $PREFIX/share/antisplit || {
    echo -e "${RED}Error: Failed to clone AntiSplit repository.${NC}"
    exit 1
}

# Create launcher script
echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/antisplit << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
exec bash $PREFIX/share/antisplit/antisplit.sh "$@"
EOF

chmod +x $PREFIX/bin/antisplit

echo -e "${GREEN}AntiSplit installed successfully!${NC}"
echo -e "${YELLOW}Usage:${NC}"
echo "  antisplit                    # Launch interactive mode"
echo "  antisplit /path/to/apks      # Process APK files"
exit 0
