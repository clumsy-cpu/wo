#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling AntiSplit...${NC}"

# Remove launcher script
if [ -f "$PREFIX/bin/antisplit" ]; then
    rm -f $PREFIX/bin/antisplit
    echo -e "${GREEN}Removed launcher script${NC}"
fi

# Remove cloned repository
if [ -d "$PREFIX/share/antisplit" ]; then
    rm -rf $PREFIX/share/antisplit
    echo -e "${GREEN}Removed AntiSplit repository${NC}"
fi

echo -e "${GREEN}AntiSplit completely removed${NC}"
exit 0
