#!/data/data/com.termux/files/usr/bin/bash

INSTALL_DIR="$PREFIX/share/apkpatcher"
LAUNCHER="$PREFIX/bin/apkpatcher"

# Check if INSTALL_DIR exists and remove it
if [ -d "$INSTALL_DIR" ]; then
    echo "[*] Removing existing directory $INSTALL_DIR..."
    rm -rf "$INSTALL_DIR" || exit 1
fi

# Clone apkpatcher
echo "[*] Cloning apkpatcher..."
git clone --quiet https://github.com/Anon4You/APKpatcher.git "$INSTALL_DIR" || exit 1

# Create symlink and set permissions
ln -sf "$INSTALL_DIR/APKpatcher.sh" "$LAUNCHER"
chmod +x "$LAUNCHER"
