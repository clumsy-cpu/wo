#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing apksearch 1.3.5...${NC}"

echo -e "${YELLOW}Installing apksearch via pip...${NC}"
pip install -U apksearch || {
    echo -e "${RED}Error: Failed to install apksearch.${NC}"
    exit 1
}

echo -e "${GREEN}apksearch installed successfully!${NC}"
exit 0
