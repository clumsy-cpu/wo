#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling apksearch...${NC}"

pip uninstall -y apksearch 2>/dev/null || {
    echo -e "${YELLOW}apksearch not found or already uninstalled.${NC}"
}

echo -e "${GREEN}apksearch completely removed${NC}"
exit 0
