#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing blutter...${NC}"

if [ -d "$PREFIX/share/blutter" ]; then
    echo -e "${YELLOW}Removing existing blutter directory...${NC}"
    rm -rf $PREFIX/share/blutter
fi

echo -e "${YELLOW}Cloning blutter repository...${NC}"
git clone https://github.com/dedshit/blutter-termux.git $PREFIX/share/blutter || {
    echo -e "${RED}Error: Failed to clone blutter repository.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing Python dependencies...${NC}"
pip install requests pyelftools || {
    echo -e "${RED}Error: Failed to install Python dependencies.${NC}"
    exit 1
}

echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/blutter << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
exec python $PREFIX/share/blutter/blutter.py "$@"
EOF

chmod +x $PREFIX/bin/blutter

echo -e "${GREEN}blutter installed successfully!${NC}"
exit 0
