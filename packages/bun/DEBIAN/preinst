#!/data/data/com.termux/files/usr/bin/bash

ARCH=$(uname -m)

case "$ARCH" in
    aarch64)
        exit 0
        ;;
    x86_64)
        exit 0
        ;;
    *)
        echo "Error: bun is only available for aarch64 (ARM64) or x86_64 (AMD64) architectures." >&2
        echo "Your architecture: $ARCH" >&2
        exit 1
        ;;
esac
