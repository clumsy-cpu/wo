#!/data/data/com.termux/files/usr/bin/bash

echo "Installing catsay..."

INSTALL_DIR="$PREFIX/share/catsay"

# Remove old directory (if present) and clone the repository
rm -rf "$INSTALL_DIR"
git clone https://github.com/Anon4You/catsay.git "$INSTALL_DIR" || exit 1

# Create launcher with cd
mkdir -p "$PREFIX/bin"
cat > "$PREFIX/bin/catsay" << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/catsay"
exec python catsay.py "$@"
EOF
chmod +x "$PREFIX/bin/catsay"

echo "catsay installation finished."
exit 0
