#!/data/data/com.termux/files/usr/bin/bash

set -e

INSTALL_DIR="$PREFIX/share/d-tect"

# Remove old installation (if any)
rm -rf "$INSTALL_DIR"

# Clone the repository
echo "Cloning D‑TECT repository..."
git clone https://github.com/bibortone/D-Tech.git "$INSTALL_DIR"

# Create executable launcher
echo "Creating launcher..."
cat > "$PREFIX/bin/d-tect" << "EOF"
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/d-tect" && python2 d-tect.py "$@"
EOF

chmod +x "$PREFIX/bin/d-tect"

echo "Installation finished."
exit 0
