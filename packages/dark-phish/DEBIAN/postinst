#!/data/data/com.termux/files/usr/bin/bash

set -e

echo "Installing Dark-Phish..."

pip install requests wget pyshorteners bs4 || exit 1

INSTALL_DIR="$PREFIX/share/dark-phish"
rm -rf "$INSTALL_DIR"
git clone https://github.com/Cyber-Anonymous/Dark-Phish.git "$INSTALL_DIR" || exit 1

cat > "$PREFIX/bin/dark-phish" << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/dark-phish"
exec python dark-phish.py "$@"
EOF

chmod +x "$PREFIX/bin/dark-phish"

echo "Dark-Phish installed successfully."
exit 0
