#!/data/data/com.termux/files/usr/bin/bash
git clone --quiet https://github.com/ykankaya/DarkSploit.git ${HOME}/.local/share/DrXp
[[ -d ${HOME}/.local/share/DrXp ]] && {
  echo "Installing requirements ..."
  chmod 751 -R ${HOME}/.local/share/DrXp
  pip2 install requests urllib3 BeautifulSoup mechanize google colorama wget -q
  echo "[*] darksploit-framework installation finished."
  echo "[*] Run 'darksploit' to execute it."
} || {
 echo -en "\e[31mE:\e[0m DrXp directory missing ... \e[33mAborting.\e[0m\n"
}
exit 0
