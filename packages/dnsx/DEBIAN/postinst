#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/dnsx"
DNSX_BIN="$HOME/go/bin/dnsx"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing dnsx...${NC}"
go install -v github.com/projectdiscovery/dnsx/cmd/dnsx@latest || {
    echo -e "${RED}Error: Failed to install dnsx. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$DNSX_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$DNSX_BIN" ]; then
    echo -e "${GREEN}dnsx installed successfully. Run 'dnsx -h' to verify.${NC}"
else
    echo -e "${RED}Error: dnsx binary not found at $DNSX_BIN.${NC}"
    exit 1
fi
