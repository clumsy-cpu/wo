#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

VERSION="2.12.0"

echo -e "${GREEN}Installing dpt-shell $VERSION...${NC}"

mkdir -p $PREFIX/share/dpt-shell

DOWNLOAD_URL="https://github.com/luoyesiqiu/dpt-shell/releases/download/v$VERSION/dpt-shell-v$VERSION.zip"

echo -e "${YELLOW}Downloading dpt-shell...${NC}"
curl -L -o $TMPDIR/dpt-shell.zip $DOWNLOAD_URL || {
    echo -e "${RED}Error: Failed to download dpt-shell.${NC}"
    exit 1
}

echo -e "${YELLOW}Extracting dpt-shell...${NC}"
unzip -q $TMPDIR/dpt-shell.zip -d $TMPDIR/ || {
    echo -e "${RED}Error: Failed to extract dpt-shell.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing dpt.jar...${NC}"
mv $TMPDIR/executable/* $PREFIX/share/dpt-shell/ || {
    echo -e "${RED}Error: Failed to move dpt.jar from executable directory.${NC}"
    exit 1
}

echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/dpt-shell << 'EOF'
#!/data/data/com.termux/files/usr/bin/sh
exec java -jar $PREFIX/share/dpt-shell/dpt.jar "$@"
EOF

chmod +x $PREFIX/bin/dpt-shell

rm -f $TMPDIR/dpt-shell.zip
rm -rf $TMPDIR/executable

echo -e "${GREEN}dpt-shell installed successfully!${NC}"
exit 0
