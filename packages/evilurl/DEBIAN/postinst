#!/data/data/com.termux/files/usr/bin/bash
set -e

EVILURL_DIR="$PREFIX/share/evilurl"
LAUNCHER="$PREFIX/bin/evilurl"

echo "[*] Installing EvilURL 3.0..."
[ -d "$EVILURL_DIR" ] && { echo "[*] Removing old installation..."; rm -rf "$EVILURL_DIR"; }

echo "[*] Cloning repository..."
git clone --depth=1 https://github.com/UndeadSec/EvilURL.git "$EVILURL_DIR"

echo "[*] Installing Python dependencies..."
python -m pip install python-nmap python-whois

echo "[*] Creating launcher..."
cat > "$LAUNCHER" << EOF
#!/data/data/com.termux/files/usr/bin/bash
unset LD_PRELOAD
cd "$EVILURL_DIR" && python evilurl.py "\$@"
EOF
chmod +x "$LAUNCHER"

echo -e "\n[√] EvilURL installed successfully!"
echo "Usage:"
echo "  evilurl -h          # Show help menu"

exit 0
