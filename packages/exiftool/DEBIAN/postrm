#!/data/data/com.termux/files/usr/bin/bash

EXIFTOOL_DIR="$PREFIX/share/exiftool"
LAUNCHER="$PREFIX/bin/exiftool"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling exiftool...${NC}"

if [ -f "$LAUNCHER" ]; then
    rm -f "$LAUNCHER" && echo -e "${GREEN}✓ Removed launcher${NC}" || \
    echo -e "${RED}✗ Failed to remove launcher${NC}"
fi

if [ -d "$EXIFTOOL_DIR" ]; then
    rm -rf "$EXIFTOOL_DIR" && echo -e "${GREEN}✓ Removed exiftool directory${NC}" || \
    echo -e "${RED}✗ Failed to remove exiftool directory${NC}"
fi

echo -e "${GREEN}Uninstallation complete${NC}"
exit 0
