#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing ffmpegp 1.30...${NC}"

echo -e "${YELLOW}Installing ffmpegp via pip...${NC}"
pip install ffmpegp==1.30 || {
    echo -e "${RED}Error: Failed to install ffmpegp.${NC}"
    exit 1
}

echo -e "${GREEN}ffmpegp installed successfully!${NC}"
exit 0
