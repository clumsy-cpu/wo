#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling ffmpegp...${NC}"

pip uninstall -y ffmpegp 2>/dev/null || {
    echo -e "${YELLOW}ffmpegp not found or already uninstalled.${NC}"
}

echo -e "${GREEN}ffmpegp completely removed${NC}"
exit 0
