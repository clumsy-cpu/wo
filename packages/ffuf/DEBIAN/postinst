#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/ffuf"
FFUF_BIN="$HOME/go/bin/ffuf"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing ffuf...${NC}"
go install -v github.com/ffuf/ffuf/v2@latest || {
    echo -e "${RED}Error: Failed to install ffuf. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$FFUF_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$FFUF_BIN" ]; then
    echo -e "${GREEN}ffuf installed successfully. Run 'ffuf -h' to verify.${NC}"
else
    echo -e "${RED}Error: ffuf binary not found at $FFUF_BIN.${NC}"
    exit 1
fi
