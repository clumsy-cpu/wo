#!/data/data/com.termux/files/usr/bin/bash
set -e

echo "[*] Checking device architecture..."
ARCH=$(uname -m)

if [ "$ARCH" != "aarch64" ]; then
    echo "[!] ERROR: This package requires aarch64 architecture"
    echo "[!] Your device architecture: $ARCH"
    echo "[!] Installation cannot continue"
    exit 1
fi

echo "[√] Architecture check passed: aarch64"
exit 0
