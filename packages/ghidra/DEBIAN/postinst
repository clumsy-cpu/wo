#!/data/data/com.termux/files/usr/bin/bash
set -e

GHIDRA_DIR="$PREFIX/share/ghidra"
DESKTOP_DIR="$PREFIX/share/applications"
DOWNLOAD_URL="https://github.com/NationalSecurityAgency/ghidra/releases/download/Ghidra_12.0.4_build/ghidra_12.0.4_PUBLIC_20260303.zip"

echo "[*] Downloading Ghidra 12.0.4..."
mkdir -p "$TMPDIR"
wget --show-progress -q --progress=bar:force:noscroll \
     "$DOWNLOAD_URL" -O "$TMPDIR/ghidra.zip"

echo "[*] Installing to $GHIDRA_DIR..."
[ -d "$GHIDRA_DIR" ] && rm -rf "$GHIDRA_DIR"
unzip -q "$TMPDIR/ghidra.zip" -d "$PREFIX/share"
mv "$PREFIX/share/ghidra_12.0.4_PUBLIC" "$GHIDRA_DIR"

echo "[*] Creating launcher..."
cat > "$PREFIX/bin/ghidra" <<EOF
#!/data/data/com.termux/files/usr/bin/bash
export _JAVA_OPTIONS="-Duser.home=\$HOME -Xmx2G"
cd "$GHIDRA_DIR" && ./ghidraRun "\$@"
EOF
chmod +x "$PREFIX/bin/ghidra"

mkdir -p "$DESKTOP_DIR"
cat > "$DESKTOP_DIR/ghidra.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Ghidra
Comment=Software Reverse Engineering Suite
Exec=ghidra
Icon=ghidra
Categories=Development;
Terminal=false
EOF

echo -e "\n[√] Ghidra installed successfully!"
echo "Run: ghidra (GUI) or ghidra --analyzeHeadless (CLI)"
exit 0
