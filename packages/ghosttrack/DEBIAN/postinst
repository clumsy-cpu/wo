#!/data/data/com.termux/files/usr/bin/bash

GHOSTTRACK_DIR="$PREFIX/share/ghosttrack"
LAUNCHER="$PREFIX/bin/ghosttrack"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing GhostTrack...${NC}"
[ -d "$GHOSTTRACK_DIR" ] && { echo "[*] Removing old installation..."; rm -rf "$GHOSTTRACK_DIR"; }

echo -e "${GREEN}Cloning repository...${NC}"
git clone --depth=1 https://github.com/HunxByts/GhostTrack.git "$GHOSTTRACK_DIR" || {
    echo -e "${RED}Error: Failed to clone GhostTrack repository.${NC}"
    exit 1
}

echo -e "${GREEN}Installing Python dependencies...${NC}"
cd "$GHOSTTRACK_DIR"
pip install -r requirements.txt || {
    echo -e "${RED}Error: Failed to install Python dependencies.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher...${NC}"
cat > "$LAUNCHER" << EOF
#!/data/data/com.termux/files/usr/bin/bash
cd "$GHOSTTRACK_DIR" && python GhostTR.py "\$@"
EOF
chmod +x "$LAUNCHER"

echo -e "${GREEN}GhostTrack installed successfully!${NC}"
echo "Run: ghosttrack"
exit 0
