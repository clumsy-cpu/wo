#!/data/data/com.termux/files/usr/bin/bash

GHOSTTRACK_DIR="$PREFIX/share/ghosttrack"
LAUNCHER="$PREFIX/bin/ghosttrack"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling GhostTrack...${NC}"

if [ -f "$LAUNCHER" ]; then
    rm -f "$LAUNCHER" && echo -e "${GREEN}‚úì Removed launcher${NC}" || \
    echo -e "${RED}‚úó Failed to remove launcher${NC}"
fi

if [ -d "$GHOSTTRACK_DIR" ]; then
    rm -rf "$GHOSTTRACK_DIR" && echo -e "${GREEN}‚úì Removed GhostTrack directory${NC}" || \
    echo -e "${RED}‚úó Failed to remove GhostTrack directory${NC}"
fi

echo -e "${GREEN}Uninstallation complete${NC}"
exit 0
