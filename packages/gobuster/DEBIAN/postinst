#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/gobuster"
GOBUSTER_BIN="$HOME/go/bin/gobuster"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing gobuster...${NC}"
go install -v github.com/OJ/gobuster/v3@latest || {
    echo -e "${RED}Error: Failed to install gobuster. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$GOBUSTER_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$GOBUSTER_BIN" ]; then
    echo -e "${GREEN}gobuster installed successfully. Run 'gobuster -h' to verify.${NC}"
else
    echo -e "${RED}Error: gobuster binary not found at $GOBUSTER_BIN.${NC}"
    exit 1
fi
