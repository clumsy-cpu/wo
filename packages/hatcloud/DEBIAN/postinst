#!/data/data/com.termux/files/usr/bin/bash

INSTALL_DIR="$PREFIX/share/hatcloud"
LAUNCHER="$PREFIX/bin/hatcloud"

echo "[*] Cloning HatCloud..."
git clone --depth 1 https://github.com/HatBashBR/HatCloud.git $INSTALL_DIR || {
    echo "[!] Failed to clone repository"
    exit 1
}

echo "[*] Creating launcher..."
cat > $LAUNCHER <<EOF
#!/data/data/com.termux/files/usr/bin/bash
cd $INSTALL_DIR && exec ruby hatcloud.rb "\$@"
EOF

chmod +x $LAUNCHER || {
    echo "[!] Failed to make launcher executable"
    exit 1
}

echo "[+] HatCloud installed! Run 'hatcloud -h' for help."
