#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/httpx"
HTTPX_BIN="$HOME/go/bin/httpx"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing httpx...${NC}"
go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest || {
    echo -e "${RED}Error: Failed to install httpx. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$HTTPX_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$HTTPX_BIN" ]; then
    echo -e "${GREEN}httpx installed successfully! Run 'httpx -version' to verify.${NC}"
else
    echo -e "${RED}Error: httpx binary not found at $HTTPX_BIN.${NC}"
    exit 1
fi
