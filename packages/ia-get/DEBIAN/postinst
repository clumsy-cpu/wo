#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing ia-get ...${NC}"

echo -e "${YELLOW}Cloning repository...${NC}"
git clone https://github.com/wimpysworld/ia-get.git $TMPDIR/ia-get || {
    echo -e "${RED}Error: Failed to clone repository.${NC}"
    exit 1
}

cd $TMPDIR/ia-get

echo -e "${YELLOW}Building with cargo...${NC}"
cargo build --release || {
    echo -e "${RED}Error: Failed to build.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing binary...${NC}"
mv target/release/ia-get $PREFIX/bin/ || {
    echo -e "${RED}Error: Failed to install binary.${NC}"
    exit 1
}

chmod +x $PREFIX/bin/ia-get

echo -e "${YELLOW}Cleaning up...${NC}"
rm -rf $TMPDIR/ia-get

echo -e "${GREEN}ia-get installed successfully!${NC}"
exit 0
