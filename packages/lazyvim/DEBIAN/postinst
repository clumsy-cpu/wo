#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing LazyVim...${NC}"

# Remove existing Neovim directories
echo -e "${YELLOW}Removing existing Neovim configurations...${NC}"
rm -rf ~/.config/nvim ~/.local/state/nvim ~/.local/share/nvim 2>/dev/null

# Install global language server
echo -e "${YELLOW}Installing vscode-langservers-extracted...${NC}"
npm install -g vscode-langservers-extracted || {
  echo -e "${RED}Error: Failed to install language server package.${NC}"
  exit 1
}

# Clone LazyVim starter template
echo -e "${YELLOW}Cloning LazyVim starter...${NC}"
git clone https://github.com/LazyVim/starter ~/.config/nvim || {
  echo -e "${RED}Error: Failed to clone LazyVim repository.${NC}"
  exit 1
}

# Remove Git metadata (to avoid version control issues)
rm -rf ~/.config/nvim/.git

echo -e "${GREEN}LazyVim installed successfully!${NC}"
echo -e "${YELLOW}To complete setup, run: nvim${NC}"
echo -e "${YELLOW}Wait for post-installation to finish.${NC}"
exit 0
