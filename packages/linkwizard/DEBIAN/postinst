#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing linkwizard...${NC}"

# Install Python dependencies
echo -e "${YELLOW}Installing Python dependencies...${NC}"
pip install rich requests bs4 pyfiglet || {
    echo -e "${RED}Error: Failed to install dependencies.${NC}"
    exit 1
}

# Create launcher
echo -e "${YELLOW}Creating launcher...${NC}"
LAUNCHER="$PREFIX/bin/linkwizard"
cat > "$LAUNCHER" << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/linkwizard"
exec python lw.py "$@"
EOF

chmod +x "$LAUNCHER"

echo -e "${GREEN}linkwizard installed successfully!${NC}"
exit 0
