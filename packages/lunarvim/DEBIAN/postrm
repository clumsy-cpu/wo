#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling LunarVim...${NC}"

# Remove LunarVim configuration and data directories
rm -rf ~/.config/nvim ~/.local/state/nvim ~/.local/share/nvim ~/.local/share/lunarvim 2>/dev/null

echo -e "${GREEN}LunarVim completely removed.${NC}"
exit 0
