#!/data/data/com.termux/files/usr/bin/bash
set -e

pip install --no-binary curl_cffi curl_cffi --force-reinstall
pip install maigret==0.6.2

echo "maigret installed successfully."
echo ""
echo "Usage examples:"
echo "  maigret username"
echo "  maigret username -o json"
echo "  maigret username -a  # Show all results"
echo "  maigret username --recursive  # Follow found accounts"
exit 0
