#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/mantra"
MANTRA_BIN="$HOME/go/bin/mantra"
GO_DIR="$HOME/go"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling mantra...${NC}"

[ -d "$GO_DIR" ] && chmod 751 -R "$GO_DIR"

if [ -f "$LAUNCHER" ]; then
    rm -f "$LAUNCHER" && echo -e "${GREEN}✓ Removed launcher${NC}" || \
    echo -e "${RED}✗ Failed to remove launcher${NC}"
fi

if [ -f "$MANTRA_BIN" ]; then
    rm -f "$MANTRA_BIN" && echo -e "${GREEN}✓ Removed binary${NC}" || \
    echo -e "${RED}✗ Failed to remove binary (try: rm -f $MANTRA_BIN)${NC}"
fi

echo -e "${GREEN}Uninstallation complete${NC}"
