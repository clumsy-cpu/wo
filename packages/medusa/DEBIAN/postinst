#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing Medusa 2.3 via NetHunter...${NC}"

# Update and install medusa using nethunter
nh apt update -y && nh apt install medusa -y || {
    echo -e "${RED}Error: Failed to install Medusa via NetHunter.${NC}"
    echo -e "${YELLOW}Make sure nethunter-cli is properly configured.${NC}"
    exit 1
}

# Create launcher script
echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/medusa << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
exec nh medusa "$@"
EOF

chmod +x $PREFIX/bin/medusa

echo -e "${GREEN}Medusa installed successfully!${NC}"
echo -e "${YELLOW}Usage examples:${NC}"
echo "  medusa -h"
echo "  medusa -M ssh -h target -U users.txt -P passwords.txt"
echo "  medusa -M ftp -h target -u admin -p password123"
echo "  medusa -M http -h target -U users.txt -P passwords.txt -m DIR:/admin"
exit 0
