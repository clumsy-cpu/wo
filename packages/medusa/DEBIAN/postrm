#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling Medusa...${NC}"

# Remove launcher script
if [ -f "$PREFIX/bin/medusa" ]; then
    rm -f $PREFIX/bin/medusa
    echo -e "${GREEN}Removed launcher script${NC}"
fi

# Remove medusa using nethunter
nh apt remove -y medusa 2>/dev/null || {
    echo -e "${YELLOW}Medusa not found or already uninstalled.${NC}"
}

echo -e "${GREEN}Medusa completely removed${NC}"
exit 0
