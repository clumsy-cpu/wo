#!/data/data/com.termux/files/usr/bin/bash
set -e

PREFIX=${PREFIX:-/data/data/com.termux/files/usr}
ARCH=$(uname -m)
VERSION="0.1.4"

case "$ARCH" in
    aarch64)
        ARCH_TARGET="arm64"
        LD_SO="ld-linux-aarch64.so.1"
        ;;
    x86_64)
        ARCH_TARGET="amd64"
        LD_SO="ld-linux-x86-64.so.2"
        ;;
    *)
        echo "Unsupported architecture: $ARCH" >&2
        exit 1
        ;;
esac

TARFILE="mimocode-linux-${ARCH_TARGET}.tar.gz"
DOWNLOAD_URL="https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v${VERSION}/${TARFILE}"
SHARE_DIR="$PREFIX/share/mimocode"
BIN_DIR="$PREFIX/bin"
LOADER="$PREFIX/glibc/lib/${LD_SO}"
REAL_BIN="$SHARE_DIR/mimo.real"
LIB_PATH="$PREFIX/glibc/lib"

mkdir -p "$SHARE_DIR" "$BIN_DIR"

echo "Downloading MiMo‑Code ${VERSION}..."
curl -fsSL "$DOWNLOAD_URL" | tar -xz -C "$SHARE_DIR"
if [ ! -f "$SHARE_DIR/mimo" ]; then
    echo "Error: mimo binary not found after extraction." >&2
    exit 1
fi
mv "$SHARE_DIR/mimo" "$REAL_BIN"
chmod +x "$REAL_BIN"

# Write wrapper C source (same as opencode, with dynamic loader)
cat > "$TMPDIR/mimocode_helper.c" << 'EOF'
#include <stdlib.h>
#include <unistd.h>
#include <string.h>
#include <stdio.h>

int main(int argc, char** argv) {
    unsetenv("LD_PRELOAD");
    unsetenv("LD_LIBRARY_PATH");

    setenv("GODEBUG", "netdns=cgo", 1);
    setenv("SSL_CERT_FILE", "/data/data/com.termux/files/usr/etc/tls/cert.pem", 1);

    char* loader = LOADER_PLACEHOLDER;
    char real_bin[] = "/data/data/com.termux/files/usr/share/mimocode/mimo.real";
    char lib_path[] = "/data/data/com.termux/files/usr/glibc/lib";

    char** new_argv = malloc((argc + 4) * sizeof(char*));
    if (!new_argv) {
        return 1;
    }

    new_argv[0] = loader;
    new_argv[1] = "--library-path";
    new_argv[2] = lib_path;
    new_argv[3] = real_bin;

    for (int i = 1; i < argc; i++) {
        new_argv[i + 3] = argv[i];
    }
    new_argv[argc + 3] = NULL;

    execv(loader, new_argv);
    perror("execv");
    free(new_argv);
    return 1;
}
EOF

# Replace placeholder with actual loader path
sed -i "s|LOADER_PLACEHOLDER|\"$LOADER\"|g" "$TMPDIR/mimocode_helper.c"

# Compile wrapper
clang -O2 -o "$BIN_DIR/mimo" "$TMPDIR/mimocode_helper.c"
chmod +x "$BIN_DIR/mimo"

rm -f "$TMPDIR/mimocode_helper.c"

echo "MiMo‑Code $VERSION installed successfully."
echo "Run 'mimo' to start."
exit 0
