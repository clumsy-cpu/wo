#!/data/data/com.termux/files/usr/bin/bash

INSTALL_DIR="$PREFIX/share/nikto"
LAUNCHER="$PREFIX/bin/nikto"

# Clone Nikto
echo "[*] Cloning Nikto..."
git clone --depth 1 https://github.com/sullo/nikto.git "$INSTALL_DIR" || exit 1

# Force-install Net::SSLeay via CPAN
echo "[*] Installing Net::SSLeay (this may take 2-5 minutes)..."
cpan -fi Net::SSLeay

# Create launcher with SSL verification
echo "[*] Creating launcher..."
cat > "$LAUNCHER" <<'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/nikto/program"
perl -MNet::SSLeay -e 'print "SSL Ready\n"' || {
    echo "ERROR: SSL support broken. Reinstall with:"
    exit 1
}
exec perl nikto.pl "$@"
EOF

chmod +x "$LAUNCHER"
echo "[+] Nikto ready with SSL! Test with: nikto -h https://example.com"
