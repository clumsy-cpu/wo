#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing Numinfo...${NC}"

INSTALL_DIR="$PREFIX/share/numinfo"

# Remove existing installation if present
if [ -d "$INSTALL_DIR" ]; then
    echo -e "${YELLOW}Removing existing Numinfo directory...${NC}"
    rm -rf "$INSTALL_DIR"
fi

# Clone repository
echo -e "${YELLOW}Cloning repository...${NC}"
git clone https://github.com/Anon4You/NumInfo.git "$INSTALL_DIR" || {
    echo -e "${RED}Error: Failed to clone repository.${NC}"
    exit 1
}

# Install requirements
echo -e "${YELLOW}Installing Python dependencies...${NC}"
cd "$INSTALL_DIR"
pip install -r requirements.txt || {
    echo -e "${RED}Error: Failed to install requirements.${NC}"
    exit 1
}

# Create launcher (direct execution, no cd)
echo -e "${YELLOW}Creating launcher...${NC}"
cat > "$PREFIX/bin/numinfo" << EOF
#!/data/data/com.termux/files/usr/bin/bash
exec python "$INSTALL_DIR/numinfo.py" "\$@"
EOF

chmod +x "$PREFIX/bin/numinfo"

echo -e "${GREEN}Numinfo installed successfully!${NC}"
echo ""
echo -e "${YELLOW}To use this tool, you need API keys:${NC}"
echo "  export NUMVERIFY_API_KEY=your_key_here"
echo "  export ABSTRACT_API_KEY=your_key_here"
echo ""
echo -e "${YELLOW}Add these lines to your ~/.bashrc or set them before running.${NC}"
echo -e "${YELLOW}Run 'numinfo' to start.${NC}"
exit 0
