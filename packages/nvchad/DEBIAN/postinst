#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing nvchad 3.0...${NC}"

# Remove existing nvim directories
rm -rf ~/.config/nvim ~/.local/state/nvim ~/.local/share/nvim 2>/dev/null
npm install -g vscode-langservers-extracted
# Install NvChad starter template
echo -e "${YELLOW}Installing NvChad starter...${NC}"
git clone https://github.com/NvChad/starter ~/.config/nvim --depth 1 || {
    echo -e "${RED}Error: Failed to clone NvChad starter repository.${NC}"

    exit 1
}

echo -e "${GREEN}nvchad installed successfully!${NC}"
echo -e "${YELLOW}To complete setup, run: nvim${NC}"
echo -e "${YELLOW}Wait for post-installation to finish.${NC}"
exit 0
