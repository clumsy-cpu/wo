#!/data/data/com.termux/files/usr/bin/bash

OBP_DIR="$PREFIX/share/openbullet"
LAUNCHER="$PREFIX/bin/openbullet"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing openbullet 1.0.2...${NC}"
[ -d "$OBP_DIR" ] && { echo "[*] Removing old installation..."; rm -rf "$OBP_DIR"; }

echo -e "${GREEN}Cloning repository...${NC}"
git clone --depth=1 https://github.com/esfelurm/OpenBullet.git "$OBP_DIR" || {
    echo -e "${RED}Error: Failed to clone openbullet repository.${NC}"
    exit 1
}

echo -e "${GREEN}Installing Python dependencies...${NC}"
pip install requests bs4 colorama jsonpath_ng || {
    echo -e "${RED}Error: Failed to install Python dependencies.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher...${NC}"
cat > "$LAUNCHER" << EOF
#!/data/data/com.termux/files/usr/bin/bash
cd "$OBP_DIR" && python OpenBullet.py "\$@"
EOF
chmod +x "$LAUNCHER"

echo -e "${GREEN}openbullet installed successfully!${NC}"
echo "Run: openbullet"
exit 0
