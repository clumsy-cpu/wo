#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
NC='\033[0m'

ARCH=$(uname -m)

if [ "$ARCH" != "aarch64" ]; then
    echo -e "${RED}Error: OpenBullet2 only supports aarch64 architecture.${NC}"
    echo "Your architecture: $ARCH"
    echo "This package cannot be installed on this device."
    exit 1
fi

exit 0
