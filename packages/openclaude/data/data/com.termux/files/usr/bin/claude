#!/data/data/com.termux/files/usr/bin/env bash

# openclaude wrapper for Termux by Alienkrishn
# Fixes openclaude shell/environment issues by running inside termux-chroot

npmroot=$(npm root -g)
openclaude="$npmroot/@gitlawb/openclaude/dist/cli.mjs"

# Run inside chroot with node
exec termux-chroot node "$openclaude" "$@"
