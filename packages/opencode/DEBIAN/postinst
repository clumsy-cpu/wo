#!/data/data/com.termux/files/usr/bin/bash
set -e
 
PREFIX=${PREFIX:-/data/data/com.termux/files/usr}
VERSION="1.18.2"
TARFILE="opencode-linux-arm64.tar.gz"
DOWNLOAD_URL="https://github.com/anomalyco/opencode/releases/download/v${VERSION}/${TARFILE}"

SHARE_DIR="$PREFIX/share/opencode"
BIN_DIR="$PREFIX/bin"
LOADER="$PREFIX/glibc/lib/ld-linux-aarch64.so.1"
REAL_BIN="$SHARE_DIR/opencode.real"
LIB_PATH="$PREFIX/glibc/lib"

# Create directories
mkdir -p "$SHARE_DIR" "$BIN_DIR"

# Download and extract
echo "Downloading opencode ${VERSION}..."
curl -fsSL "$DOWNLOAD_URL" | tar -xz -C "$SHARE_DIR"
if [ ! -f "$SHARE_DIR/opencode" ]; then
    echo "Error: opencode binary not found after extraction." >&2
    exit 1
fi
mv "$SHARE_DIR/opencode" "$REAL_BIN"
chmod +x "$REAL_BIN"

# Write wrapper source
cat > "$TMPDIR/opencode_helper.c" << 'EOF'
#include <stdlib.h>
#include <unistd.h>
#include <string.h>
#include <libgen.h>
#include <limits.h>
#include <stdio.h>

int main(int argc, char** argv) {
    unsetenv("LD_PRELOAD");
    unsetenv("LD_LIBRARY_PATH");

    setenv("GODEBUG", "netdns=cgo", 1);
    setenv("SSL_CERT_FILE", "/data/data/com.termux/files/usr/etc/tls/cert.pem", 1);

    char* loader = "/data/data/com.termux/files/usr/glibc/lib/ld-linux-aarch64.so.1";
    char real_bin[] = "/data/data/com.termux/files/usr/share/opencode/opencode.real";
    char lib_path[] = "/data/data/com.termux/files/usr/glibc/lib";

    char** new_argv = malloc((argc + 4) * sizeof(char*));
    if (!new_argv) {
        return 1;
    }

    new_argv[0] = loader;
    new_argv[1] = "--library-path";
    new_argv[2] = lib_path;
    new_argv[3] = real_bin;

    for (int i = 1; i < argc; i++) {
        new_argv[i + 3] = argv[i];
    }
    new_argv[argc + 3] = NULL;

    execv(loader, new_argv);
    perror("execv");
    free(new_argv);
    return 1;
}
EOF

# Compile wrapper
clang -O2 -o "$BIN_DIR/opencode" "$TMPDIR/opencode_helper.c"
chmod +x "$BIN_DIR/opencode"

# Clean up temporary source
rm -f "$TMPDIR/opencode_helper.c"

echo "OpenCode $VERSION installed successfully."
echo "Run 'opencode' to start."
exit 0
