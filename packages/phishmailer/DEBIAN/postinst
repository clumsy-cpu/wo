#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing phishmailer 2.2...${NC}"

if [ -d "$PREFIX/share/phishmailer" ]; then
    echo -e "${YELLOW}Removing existing phishmailer directory...${NC}"
    rm -rf $PREFIX/share/phishmailer
fi

echo -e "${YELLOW}Cloning phishmailer repository...${NC}"
git clone https://github.com/BiZken/PhishMailer.git $PREFIX/share/phishmailer || {
    echo -e "${RED}Error: Failed to clone phishmailer repository.${NC}"
    exit 1
}

echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/phishmailer << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd $PREFIX/share/phishmailer
exec python PhishMailer.py "$@"
EOF

chmod +x $PREFIX/bin/phishmailer

echo -e "${GREEN}phishmailer installed successfully!${NC}"
exit 0
