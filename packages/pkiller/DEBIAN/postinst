#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing PKiller...${NC}"

if [ -d "$PREFIX/share/PKiller" ]; then
    echo -e "${YELLOW}Removing existing PKiller directory...${NC}"
    rm -rf $PREFIX/share/PKiller
fi

echo -e "${YELLOW}Cloning PKiller repository...${NC}"
git clone https://github.com/Anon4You/PKiller.git $PREFIX/share/PKiller || {
    echo -e "${RED}Error: Failed to clone PKiller repository.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing Python dependencies...${NC}"
pip install termcolor -q || {
    echo -e "${RED}Error: Failed to install termcolor.${NC}"
    exit 1
}

echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/pkiller << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
clear
exec python $PREFIX/share/PKiller/pkiller.py "$@"
EOF

chmod +x $PREFIX/bin/pkiller

echo -e "${GREEN}PKiller installed successfully!${NC}"
exit 0
