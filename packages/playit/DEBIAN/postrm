#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling Playit...${NC}"

# Remove playit binary
if [ -f "$PREFIX/bin/playit-cli" ]; then
    rm -f $PREFIX/bin/playit-cli
    echo -e "${GREEN}Removed playit binary${NC}"
fi

echo -e "${GREEN}Playit completely removed${NC}"
exit 0
