#!/data/data/com.termux/files/usr/bin/bash

# Get Python version (e.g. "3.10")
PYVER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')

echo "[*] Installing build dependencies..."
pip install --upgrade setuptools wheel packaging pyproject_metadata cython meson-python versioneer || {
    echo "[!] Failed to install build tools"
    exit 1
}

echo "[*] Building Pandas with Python$PYVER linkage..."
MAKEFLAGS="-j$(nproc)" \
LDFLAGS="-lpython$PYVER" \
pip install --no-build-isolation --no-cache-dir pandas || {
    echo "[!] Build failed. Common fixes:"
    echo "    1. Run: pkg update && pkg upgrade"
    echo "    2. Check storage (>1GB free recommended)"
    echo "    3. Ensure all control file dependencies are installed"
    exit 1
}

echo "[+] Pandas installed successfully!"
echo "    Test with: python3 -c 'import pandas; print(pandas.__version__)'"
