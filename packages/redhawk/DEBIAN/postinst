#!/data/data/com.termux/files/usr/bin/bash
rhawkDir="$PREFIX/var/rhawk"
git clone --quiet https://github.com/Tuhinshubhra/RED_HAWK.git $rhawkDir

[[ -d $rhawkDir ]] && {
  chmod 751 -R $rhawkDir
} || {
 echo -en "\e[31mE:\e[0m rhawk directory missing ... \e[33mAborting.\e[0m\n"
}
printf "\n[+] RED_HAWK installed successfully"
printf "\n[+] Execute it by typing rhawk\n"
exit 0
