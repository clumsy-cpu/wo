#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing rkpairip...${NC}"

echo -e "${YELLOW}Installing pairip via pip...${NC}"
pip install Pairip==5.2 || {
    echo -e "${RED}Error: Failed to install pairip.${NC}"
    exit 1
}

echo -e "${GREEN}rkpairip installed successfully!${NC}"
exit 0
