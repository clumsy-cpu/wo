#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling SEToolkit...${NC}"

if [ -f "$PREFIX/bin/setoolkit" ]; then
    rm -f "$PREFIX/bin/setoolkit" && echo -e "${GREEN}✓ Removed launcher${NC}" || \
    echo -e "${RED}✗ Failed to remove launcher${NC}"
fi

read -p "Remove SEToolkit from NetHunter? [y/N]: " choice
[[ "$choice" =~ [yY] ]] && {
    nh apt remove set -y && \
    echo -e "${GREEN}✓ SEToolkit removed from NetHunter${NC}" || \
    echo -e "${RED}✗ Failed to remove from NetHunter${NC}"
}

echo -e "${GREEN}Uninstallation complete${NC}"
exit 0
