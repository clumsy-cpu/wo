#!/data/data/com.termux/files/usr/bin/bash

SILVEREYE_DIR="$PREFIX/share/silverinstaeye"
LAUNCHER="$PREFIX/bin/silverinstaeye"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling SilverInstaEye...${NC}"

if [ -f "$LAUNCHER" ]; then
    rm -f "$LAUNCHER" && echo -e "${GREEN}✓ Removed launcher${NC}" || \
    echo -e "${RED}✗ Failed to remove launcher${NC}"
fi

if [ -d "$SILVEREYE_DIR" ]; then
    rm -rf "$SILVEREYE_DIR" && echo -e "${GREEN}✓ Removed SilverInstaEye directory${NC}" || \
    echo -e "${RED}✗ Failed to remove SilverInstaEye directory${NC}"
fi

echo -e "${GREEN}Uninstallation complete${NC}"
exit 0
