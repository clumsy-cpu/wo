#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing snoop...${NC}"

INSTALL_DIR="$PREFIX/share/snoop"
LAUNCHER="$PREFIX/bin/snoop"

# Remove existing installation if present
if [ -d "$INSTALL_DIR" ]; then
    echo -e "${YELLOW}Removing existing snoop directory...${NC}"
    rm -rf "$INSTALL_DIR"
fi

# Clone repository
echo -e "${YELLOW}Cloning snoop repository...${NC}"
git clone --quiet https://github.com/snooppr/snoop.git "$INSTALL_DIR" || {
    echo -e "${RED}Error: Failed to clone repository.${NC}"
    exit 1
}

# Install requirements
echo -e "${YELLOW}Installing Python dependencies...${NC}"
cd "$INSTALL_DIR"
pip install -r requirements.txt -q || {
    echo -e "${RED}Error: Failed to install requirements.${NC}"
    exit 1
}

# Create launcher
echo -e "${YELLOW}Creating launcher...${NC}"
cat > "$LAUNCHER" << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd "$PREFIX/share/snoop"
exec python snoop.py "$@"
EOF

chmod +x "$LAUNCHER"

echo -e "${GREEN}snoop installed successfully!${NC}"
exit 0
