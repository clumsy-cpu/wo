#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling snoop...${NC}"

# Remove launcher
if [ -f "$PREFIX/bin/snoop" ]; then
    rm -f "$PREFIX/bin/snoop"
    echo -e "${GREEN}Removed launcher script${NC}"
fi

# Remove installation directory
if [ -d "$PREFIX/share/snoop" ]; then
    rm -rf "$PREFIX/share/snoop"
    echo -e "${GREEN}Removed snoop directory${NC}"
fi

echo -e "${GREEN}snoop completely removed${NC}"
exit 0
