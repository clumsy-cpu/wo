#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing sploitscan 0.14.3...${NC}"

echo -e "${YELLOW}Installing sploitscan via pip...${NC}"
pip install sploitscan==0.14.3 || {
    echo -e "${RED}Error: Failed to install sploitscan.${NC}"
    exit 1
}

echo -e "${GREEN}sploitscan installed successfully!${NC}"
exit 0
