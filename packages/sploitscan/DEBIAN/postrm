#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling sploitscan...${NC}"

pip uninstall -y sploitscan 2>/dev/null || {
    echo -e "${YELLOW}sploitscan not found or already uninstalled.${NC}"
}

echo -e "${GREEN}sploitscan completely removed${NC}"
exit 0
