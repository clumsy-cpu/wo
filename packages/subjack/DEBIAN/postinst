#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/subjack"
SUBJACK_BIN="$HOME/go/bin/subjack"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing subjack...${NC}"
go install -v github.com/haccer/subjack@latest || {
    echo -e "${RED}Error: Failed to install subjack. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$SUBJACK_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$SUBJACK_BIN" ]; then
    echo -e "${GREEN}subjack installed successfully. Run 'subjack -h' to verify.${NC}"
else
    echo -e "${RED}Error: subjack binary not found at $SUBJACK_BIN.${NC}"
    exit 1
fi
