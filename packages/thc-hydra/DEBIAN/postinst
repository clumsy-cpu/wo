#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing THC-Hydra...${NC}"

# Clone THC-Hydra repository
echo -e "${YELLOW}Cloning THC-Hydra repository...${NC}"
git clone https://github.com/vanhauser-thc/thc-hydra.git $TMPDIR/thc-hydra || {
    echo -e "${RED}Error: Failed to clone THC-Hydra repository.${NC}"
    exit 1
}

cd $TMPDIR/thc-hydra

# Build process
echo -e "${YELLOW}Building THC-Hydra...${NC}"

# Clean previous builds
make clean 2>/dev/null || true

# Configure with prefix
echo -e "${YELLOW}Configuring build...${NC}"
sh configure --prefix=$PREFIX || {
    echo -e "${RED}Error: Configuration failed.${NC}"
    exit 1
}

# Compile
echo -e "${YELLOW}Compiling...${NC}"
make || {
    echo -e "${RED}Error: Compilation failed.${NC}"
    exit 1
}

# Install
echo -e "${YELLOW}Installing...${NC}"
make install || {
    echo -e "${RED}Error: Installation failed.${NC}"
    exit 1
}

# Cleanup
rm -rf $TMPDIR/thc-hydra

echo -e "${GREEN}THC-Hydra installed successfully!${NC}"
echo -e "${YELLOW}Usage examples:${NC}"
echo "  hydra -l user -P passlist.txt ssh://target"
echo "  hydra -L users.txt -p password ftp://target"
echo "  hydra -l admin -P passwords.txt http-get://target/login"
echo "  hydra -h for full help"
exit 0
