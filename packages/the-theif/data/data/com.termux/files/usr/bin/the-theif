#!/usr/bin/env python
import os
import sys
import time
import fileinput
import configparser
from pathlib import Path
from rich.console import Console
from rich.prompt import Prompt
from rich.panel import Panel
from rich.table import Table
from rich.progress import Progress, SpinnerColumn, TextColumn

# ---- Constants ----
VERSION = "2.1"
CONFIG_DIR = Path.home() / ".config"
CONFIG_FILE = CONFIG_DIR / "the-theif.conf"
DEFAULT_CONFIG = {
    "BOT_TOKEN": "",
    "CHAT_ID": "",
}

# ---- Console setup ----
console = Console()

# ---- Helper functions ----
def load_config():
    """Load config from ~/.config/the-theif.conf, create if missing."""
    config = configparser.ConfigParser()
    if not CONFIG_FILE.exists():
        CONFIG_DIR.mkdir(parents=True, exist_ok=True)
        config["DEFAULT"] = DEFAULT_CONFIG
        with open(CONFIG_FILE, "w") as f:
            config.write(f)
        console.print("[yellow]Config file created at {}. Please configure it later.[/yellow]".format(CONFIG_FILE))
    else:
        config.read(CONFIG_FILE)
    return config

def save_config(bot_token, chat_id):
    """Save bot token and chat ID to config."""
    config = configparser.ConfigParser()
    config["DEFAULT"] = {
        "BOT_TOKEN": bot_token,
        "CHAT_ID": chat_id,
    }
    with open(CONFIG_FILE, "w") as f:
        config.write(f)
    console.print("[green]Configuration saved to {}[/green]".format(CONFIG_FILE))

def update_config_interactive():
    """Interactive menu to update bot token and chat ID."""
    config = load_config()
    current_token = config["DEFAULT"].get("BOT_TOKEN", "")
    current_chat = config["DEFAULT"].get("CHAT_ID", "")

    console.print(Panel.fit(
        "[bold cyan]Current settings:[/bold cyan]\n"
        f"Bot Token : {current_token or '[red]Not set[/red]'}\n"
        f"Chat ID   : {current_chat or '[red]Not set[/red]'}",
        title="Configuration"
    ))

    new_token = Prompt.ask("Enter new Bot Token", default=current_token)
    new_chat = Prompt.ask("Enter new Chat ID", default=current_chat)

    if new_token != current_token or new_chat != current_chat:
        save_config(new_token, new_chat)
        console.print("[green]Configuration updated![/green]")
    else:
        console.print("[yellow]No changes made.[/yellow]")

def get_credentials():
    """Prompt user to use saved config or enter new credentials."""
    config = load_config()
    saved_token = config["DEFAULT"].get("BOT_TOKEN", "")
    saved_chat = config["DEFAULT"].get("CHAT_ID", "")

    if saved_token and saved_chat:
        console.print("[green]Saved credentials found in config.[/green]")
        if Prompt.ask("Use these credentials? (y/n)", default="y").lower() == "y":
            return saved_token, saved_chat
    # If no saved creds or user chooses not to use them, ask for new
    bot_token = Prompt.ask("Bot Token")
    chat_id = Prompt.ask("Chat ID")
    if Prompt.ask("Save these to config for future use? (y/n)", default="y").lower() == "y":
        save_config(bot_token, chat_id)
    return bot_token, chat_id

def writefile(file, old, new):
    """Replace string in file."""
    try:
        for line in fileinput.input(file, inplace=True):
            print(line.replace(old, new), end="")
    except Exception as e:
        console.print(f"[red]Error writing to {file}: {e}[/red]")
        sys.exit(1)

