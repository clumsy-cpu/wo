#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling theHarvester...${NC}"

# Remove all launcher scripts
launchers=("theHarvester" "theharvester" "restfulHarvest")
for launcher in "${launchers[@]}"; do
    if [ -f "$PREFIX/bin/$launcher" ]; then
        rm -f $PREFIX/bin/$launcher
        echo -e "${GREEN}Removed launcher: $launcher${NC}"
    fi
done

# Remove theharvester using nethunter
nh apt remove -y theharvester 2>/dev/null || {
    echo -e "${YELLOW}theHarvester not found or already uninstalled.${NC}"
}

echo -e "${GREEN}theHarvester completely removed${NC}"
exit 0
