#!/data/data/com.termux/files/usr/bin/bash

ZOO_DIR="$PREFIX/share/thezoo"
LAUNCHER="$PREFIX/bin/thezoo"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing theZoo 0.60...${NC}"
[ -d "$ZOO_DIR" ] && { echo "[*] Removing old installation..."; rm -rf "$ZOO_DIR"; }

echo -e "${GREEN}Cloning repository...${NC}"
git clone --depth=1 https://github.com/ytisf/theZoo.git "$ZOO_DIR" || {
    echo -e "${RED}Error: Failed to clone theZoo repository.${NC}"
    exit 1
}

echo -e "${GREEN}Installing Python dependencies...${NC}"
cd "$ZOO_DIR"
pip install -r requirements.txt || {
    echo -e "${RED}Error: Failed to install Python dependencies.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher...${NC}"
cat > "$LAUNCHER" << EOF
#!/data/data/com.termux/files/usr/bin/bash
cd "$ZOO_DIR" && python theZoo.py "\$@"
EOF
chmod +x "$LAUNCHER"

echo -e "${GREEN}theZoo installed successfully!${NC}"
echo "Run: thezoo"
echo "Warning: Contains live malware samples - use with caution!"
exit 0
