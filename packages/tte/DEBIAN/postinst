#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing tte 0.14.2...${NC}"

echo -e "${YELLOW}Installing terminaltexteffects via pip...${NC}"
pip install terminaltexteffects==0.14.2 || {
    echo -e "${RED}Error: Failed to install terminaltexteffects.${NC}"
    exit 1
}

echo -e "${GREEN}tte installed successfully!${NC}"
exit 0
