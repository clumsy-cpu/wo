#!/data/data/com.termux/files/usr/bin/bash
venomDir="$PREFIX/var/venom"
git clone --quiet https://github.com/Anon4You/Venom $venomDir

[[ -d $venomDir ]] && {
  echo "Installing requirements ..."
  chmod 751 -R $venomDir
  npm -g install tunnelmole
} || {
 echo -en "\e[31mE:\e[0m Venom directory missing ... \e[33mAborting.\e[0m\n"
}
exit 0

