#!/data/data/com.termux/files/usr/bin/bash

LAUNCHER="$PREFIX/bin/waybackurls"
WAYBACKURLS_BIN="$HOME/go/bin/waybackurls"
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Installing waybackurls...${NC}"
go install -v github.com/tomnomnom/waybackurls@latest || {
    echo -e "${RED}Error: Failed to install waybackurls. Ensure Go is installed and internet is available.${NC}"
    exit 1
}

echo -e "${GREEN}Creating launcher at $LAUNCHER...${NC}"
cat > "$LAUNCHER" <<- EOF
#!/data/data/com.termux/files/usr/bin/bash
$WAYBACKURLS_BIN "\$@"
EOF

chmod +x "$LAUNCHER" || {
    echo -e "${RED}Error: Failed to set executable permissions for $LAUNCHER.${NC}"
    exit 1
}

if [ -x "$WAYBACKURLS_BIN" ]; then
    echo -e "${GREEN}waybackurls installed successfully. Run 'waybackurls -h' to verify.${NC}"
else
    echo -e "${RED}Error: waybackurls binary not found at $WAYBACKURLS_BIN.${NC}"
    exit 1
fi
