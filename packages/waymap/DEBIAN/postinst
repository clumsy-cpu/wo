#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing waymap 7.2.0...${NC}"

if [ -d "$PREFIX/share/waymap" ]; then
    echo -e "${YELLOW}Removing existing waymap directory...${NC}"
    rm -rf $PREFIX/share/waymap
fi

echo -e "${YELLOW}Cloning waymap repository...${NC}"
git clone --quiet https://github.com/TrixSec/waymap.git $PREFIX/share/waymap || {
    echo -e "${RED}Error: Failed to clone waymap repository.${NC}"
    exit 1
}

echo -e "${YELLOW}Installing requirements...${NC}"
cd $PREFIX/share/waymap
if [ -f "requirements.txt" ]; then
    pip install -r requirements.txt -q|| {
        echo -e "${RED}Error: Failed to install requirements.${NC}"
        exit 1
    }
fi

echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/waymap << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd $PREFIX/share/waymap
exec python waymap.py "$@"
EOF

chmod +x $PREFIX/bin/waymap

echo -e "${GREEN}waymap installed successfully!${NC}"
exit 0
