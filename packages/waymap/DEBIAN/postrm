#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}Uninstalling waymap...${NC}"

if [ -f "$PREFIX/bin/waymap" ]; then
    rm -f $PREFIX/bin/waymap
    echo -e "${GREEN}Removed launcher script${NC}"
fi

if [ -d "$PREFIX/share/waymap" ]; then
    rm -rf $PREFIX/share/waymap
    echo -e "${GREEN}Removed waymap repository${NC}"
fi

echo -e "${GREEN}waymap completely removed${NC}"
exit 0
