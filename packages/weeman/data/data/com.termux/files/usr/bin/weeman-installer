#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'
echo "Cloning repository ..."
git clone --quiet https://github.com/evait-security/weeman ${HOME}/.local/share/weeman
[[ -d ${HOME}/.local/share/weeman ]] && {
} || {
  echo -en "\e[31mE:\e[0m weeman directory missing ... \e[33mAborting.\e[0m\n"
}
exit 0
