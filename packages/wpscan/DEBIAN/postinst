#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing WPScan 3.8.28 via NetHunter...${NC}"

# Update and install wpscan using nethunter
nh apt update -y && nh apt install wpscan -y || {
    echo -e "${RED}Error: Failed to install WPScan via NetHunter.${NC}"
    echo -e "${YELLOW}Make sure nethunter-cli is properly configured.${NC}"
    exit 1
}

# Create launcher script
echo -e "${YELLOW}Creating launcher...${NC}"
cat > $PREFIX/bin/wpscan << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
exec nh wpscan "$@"
EOF

chmod +x $PREFIX/bin/wpscan

echo -e "${GREEN}WPScan installed successfully!${NC}"
echo -e "${YELLOW}Usage examples:${NC}"
echo "  wpscan --url https://example.com"
echo "  wpscan --url https://target.com --enumerate p,t,u"
echo "  wpscan --url https://site.com --passwords wordlist.txt"
echo "  wpscan --url https://blog.com --plugins-detection aggressive"
exit 0
