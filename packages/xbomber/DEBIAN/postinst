#!/data/data/com.termux/files/usr/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}Installing xbomber...${NC}"

# Clone xbomber repository to $PREFIX/share/xbomber
echo -e "${YELLOW}Cloning xbomber repository...${NC}"
git clone https://github.com/Anon4You/XBomber.git $PREFIX/share/xbomber || {
    echo -e "${RED}Error: Failed to clone xbomber repository.${NC}"
    exit 1
}

# Install Python requirements
echo -e "${YELLOW}Installing Python requirements...${NC}"
cd $PREFIX/share/xbomber
if [ -f "requirements.txt" ]; then
    pip install -r requirements.txt || {
        echo -e "${RED}Error: Failed to install requirements.${NC}"
        exit 1
    }
else
    echo -e "${YELLOW}Warning: requirements.txt not found, installing common dependencies...${NC}"
    pip install requests rich || {
        echo -e "${RED}Error: Failed to install common dependencies.${NC}"
        exit 1
    }
fi

# Create launcher script in $PREFIX/bin
echo -e "${YELLOW}Creating launcher script...${NC}"
cat > $PREFIX/bin/xbomber << 'EOF'
#!/data/data/com.termux/files/usr/bin/bash
cd $PREFIX/share/xbomber
exec python xbomber.py "$@"
EOF

# Make launcher executable
chmod +x $PREFIX/bin/xbomber

echo -e "${GREEN}xbomber installed successfully!${NC}"
exit 0

