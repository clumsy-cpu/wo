#!/data/data/com.termux/files/usr/bin/bash
set -e

ZAP_DIR="$PREFIX/share/zaproxy"
DESKTOP_DIR="$PREFIX/share/applications"
DOWNLOAD_URL="https://github.com/zaproxy/zaproxy/releases/download/w2026-03-02/ZAP_WEEKLY_D-2026-03-02.zip"

echo "[*] Downloading OWASP ZAP Weekly..."
mkdir -p "$TMPDIR"
wget --show-progress -q --progress=bar:force:noscroll \
     "$DOWNLOAD_URL" -O "$TMPDIR/zap.zip"

echo "[*] Installing to $ZAP_DIR..."
[ -d "$ZAP_DIR" ] && rm -rf "$ZAP_DIR"

# Extract and move the specific folder (ZAP_D-2026-03-02) to ZAP_DIR
unzip -q "$TMPDIR/zap.zip" -d "$TMPDIR"
mv "$TMPDIR/ZAP_D-2026-03-02" "$ZAP_DIR"

echo "[*] Creating launcher..."
cat > "$PREFIX/bin/zaproxy" <<EOF
#!/data/data/com.termux/files/usr/bin/bash
export _JAVA_OPTIONS="-Duser.home=\$HOME -Xmx1G"
cd "$ZAP_DIR" && ./zap.sh "\$@"
EOF
chmod +x "$PREFIX/bin/zaproxy"

echo "[*] Setting up desktop entry..."
mkdir -p "$DESKTOP_DIR"
cat > "$DESKTOP_DIR/zaproxy.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=OWASP ZAP (Weekly)
Comment=Web Application Security Scanner
Exec=zaproxy
Icon=zap
Categories=Security;
Terminal=false
EOF

echo -e "\n[√] OWASP ZAP Weekly installed successfully!"
echo "Run: zaproxy (GUI)"
exit 0
