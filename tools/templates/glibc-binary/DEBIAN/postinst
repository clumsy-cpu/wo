#!/data/data/com.termux/files/usr/bin/bash
# Generated by tools/new-package (glibc-binary pattern).
set -e

PREFIX=${PREFIX:-/data/data/com.termux/files/usr}
ARCH=$(uname -m)
VERSION="{{VERSION}}"
USE_SHIM="{{USE_SHIM}}"
BIN_NAME="{{BIN_NAME}}"

case "$ARCH" in
    aarch64) LD_SO="ld-linux-aarch64.so.1"; ARCH_TAG="{{TAG_AARCH64}}" ;;
    x86_64)  LD_SO="ld-linux-x86-64.so.2"; ARCH_TAG="{{TAG_X86_64}}"; USE_SHIM="no" ;;
    *) echo "Unsupported arch: $ARCH" >&2; exit 1 ;;
esac

DOWNLOAD_URL="{{URL}}"
SHARE_DIR="$PREFIX/share/{{NAME}}"
BIN_DIR="$PREFIX/bin"
LIB_DIR="$PREFIX/lib"
STAGING="$TMPDIR/{{NAME}}-staging"

mkdir -p "$SHARE_DIR" "$BIN_DIR" "$LIB_DIR" "$STAGING"

echo "Downloading {{NAME}} ${VERSION}..."
curl -fsSL -o "$STAGING/payload" "$DOWNLOAD_URL"
case "{{ARCHIVE}}" in
    zip)    unzip -q "$STAGING/payload" -d "$STAGING/x" ;;
    tar.gz) mkdir -p "$STAGING/x"; tar -xzf "$STAGING/payload" -C "$STAGING/x" ;;
    tar.xz) mkdir -p "$STAGING/x"; tar -xJf "$STAGING/payload" -C "$STAGING/x" ;;
    raw)    mkdir -p "$STAGING/x"; cp "$STAGING/payload" "$STAGING/x/$BIN_NAME" ;;
esac

ORIG_BIN=$(find "$STAGING/x" -type f -name "$BIN_NAME" | head -n1)
if [ -z "$ORIG_BIN" ]; then
    echo "Error: {{NAME}} binary not found." >&2
    exit 1
fi
REAL_BIN="$SHARE_DIR/{{NAME}}.real"
mv "$ORIG_BIN" "$REAL_BIN"
chmod +x "$REAL_BIN"
rm -rf "$STAGING"

# ── LD_PRELOAD shim: redirects EACCES-prone Android paths (aarch64 only) ──
SHIM_SO="$LIB_DIR/{{NAME}}-shim.so"
if [ "$USE_SHIM" = "yes" ]; then
cat > "$TMPDIR/{{NAME}}-shim.c" << 'SHIMEOF'
{{SHIM_C_SOURCE}}
SHIMEOF
    clang -O2 -fPIC -shared -nostdlib -o "$SHIM_SO" "$TMPDIR/{{NAME}}-shim.c"
    chmod +x "$SHIM_SO"
    rm -f "$TMPDIR/{{NAME}}-shim.c"
fi

# ── Compile launcher wrapper ─────────────────────────────────────────────
cat > "$TMPDIR/{{NAME}}_wrapper.c" << WRAPEOF
{{WRAPPER_C_SOURCE}}
WRAPEOF

SHIM_FLAG=""
[ "$USE_SHIM" = "yes" ] && SHIM_FLAG="-DSHIM_PATH=\"$SHIM_SO\""
clang -O2 $SHIM_FLAG -o "$BIN_DIR/{{NAME}}" "$TMPDIR/{{NAME}}_wrapper.c"
chmod +x "$BIN_DIR/{{NAME}}"
rm -f "$TMPDIR/{{NAME}}_wrapper.c"

echo "{{NAME}} ${VERSION} installed successfully."
exit 0
