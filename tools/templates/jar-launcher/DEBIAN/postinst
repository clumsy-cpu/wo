#!/data/data/com.termux/files/usr/bin/bash
# Generated by tools/new-package (jar-launcher pattern).

PREFIX=${PREFIX:-/data/data/com.termux/files/usr}
INSTALL_DIR="$PREFIX/share/{{NAME}}"
LAUNCHER="$PREFIX/bin/{{NAME}}"
JAR_URL="{{JAR_URL}}"

echo "[*] Setting up {{NAME}}..."
mkdir -p "$INSTALL_DIR" && cd "$INSTALL_DIR" || exit 1

echo "[*] Downloading JAR..."
curl -fsSL -o "{{NAME}}.jar" "$JAR_URL" || {
    echo "[!] Download failed. Possible fixes:"
    echo "    1. Check internet connection"
    echo "    2. Try manual download: $JAR_URL"
    exit 1
}

echo "[*] Creating launcher..."
cat > "$LAUNCHER" <<EOF
#!/data/data/com.termux/files/usr/bin/bash
exec java -jar "$INSTALL_DIR/{{NAME}}.jar" "\$@"
EOF

chmod +x "$LAUNCHER" && echo "[+] {{NAME}} ready! Usage: {{NAME}} -h" || {
    echo "[!] Launcher creation failed"
    exit 1
}
exit 0
