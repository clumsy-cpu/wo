#!/data/data/com.termux/files/usr/bin/bash
# Generated by tools/new-package (pip-build pattern).

# Get Python version (e.g. "3.12")
PYVER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')

echo "[*] Installing build dependencies..."
# always go through python3 -m pip: a bare `pip` on PATH may be a stale
# wrapper bound to a previously installed Python version
python3 -m pip install --upgrade setuptools wheel packaging {{PIP_BUILD_DEPS}} || {
    echo "[!] Failed to install build tools"
    exit 1
}

echo "[*] Building {{PIP_SPEC}} with Python$PYVER linkage..."
MAKEFLAGS="-j$(nproc)" \
LDFLAGS="-lpython$PYVER" \
python3 -m pip install --no-build-isolation --no-cache-dir {{PIP_SPEC}} || {
    echo "[!] Build failed. Common fixes:"
    echo "    1. Run: pkg update && pkg upgrade"
    echo "    2. Check storage (>1GB free recommended)"
    echo "    3. Ensure all control file dependencies are installed"
    exit 1
}

echo "[+] {{NAME}} installed successfully!"
exit 0
